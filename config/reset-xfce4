#!/bin/bash
# Script to restore XFCE4 defaults and reload the UI

echo "Restoring XFCE4 defaults from /etc/skel/admin..."

# 1. Kill core XFCE components aggressively
killall -9 xfconfd xfsettingsd xfce4-panel xfdesktop xfwm4 2>/dev/null || true
sleep 2

# 2. Backup and Restore files
if [ -d "$HOME/.config/xfce4" ]; then
    BACKUP_DIR="$HOME/.config/xfce4.bak.$(date +%Y%m%d%H%M%S)"
    echo "Backing up current config to $BACKUP_DIR"
    mv "$HOME/.config/xfce4" "$BACKUP_DIR"
fi
mkdir -p "$HOME/.config"
cp -r /etc/skel/admin/.config/xfce4 "$HOME/.config/"

# 3. Restore VNC startup files
cp -r /etc/skel/admin/.vnc/* "$HOME/.vnc/" 2>/dev/null || true

# 4. Restart core components
export DISPLAY=:1
xfsettingsd &
sleep 2

# 5. Explicitly apply shortcuts via xfconf-query
# We do this as a backup to the file restoration
echo "Applying custom keyboard shortcuts..."
CHAN="xfce4-keyboard-shortcuts"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Alt><Shift>Left" -n -t string -s "tile_left_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Alt><Shift>Right" -n -t string -s "tile_right_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Alt><Shift>Up" -n -t string -s "tile_up_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Alt><Shift>Down" -n -t string -s "tile_down_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Primary><Alt>Left" -n -t string -s "left_workspace_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Primary><Alt>Right" -n -t string -s "right_workspace_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Primary><Alt>Up" -n -t string -s "up_workspace_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/<Primary><Alt>Down" -n -t string -s "down_workspace_key"
xfconf-query -c $CHAN -p "/xfwm4/custom/override" -n -t bool -s false

# 6. Final UI Reload
xfwm4 --replace &
xfce4-panel &
xfdesktop &

echo "Reset complete. UI should be ready."
