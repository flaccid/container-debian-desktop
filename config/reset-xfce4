#!/bin/bash
# Script to restore XFCE4 defaults and reload the UI

echo "Restoring XFCE4 defaults from /etc/skel/admin..."

# 1. Kill core XFCE components
killall -9 xfconfd xfsettingsd xfce4-panel xfdesktop xfwm4 2>/dev/null || true
sleep 1

# 2. Backup and Restore files
if [ -d "$HOME/.config/xfce4" ]; then
    BACKUP_DIR="$HOME/.config/xfce4.bak.$(date +%Y%m%d%H%M%S)"
    echo "Backing up current config to $BACKUP_DIR"
    mv "$HOME/.config/xfce4" "$BACKUP_DIR"
fi
mkdir -p "$HOME/.config"
cp -r /etc/skel/admin/.config/xfce4 "$HOME/.config/"

# 3. Restore VNC startup files
cp -r /etc/skel/admin/.vnc/* "$HOME/.vnc/" 2>/dev/null || true

# 4. Restart core components
export DISPLAY=:1
xfsettingsd &
sleep 1
xfwm4 --replace &
xfce4-panel &
xfdesktop &

echo "Reset complete. UI should be ready."
