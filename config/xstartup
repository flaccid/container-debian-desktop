#!/bin/bash
xrdb $HOME/.Xresources

export XDG_RUNTIME_DIR=/run/user/1000

# Disable the X server's built-in screen saver so xfce4-screensaver's
# own timeout is the sole authority for idle locking.
xset s off

# Start clipboard sync daemon so VNC client (noVNC) clipboard panel
# receives X11 CLIPBOARD selections from terminal/opencode/xclip.
vncconfig -nowin &

exec dbus-launch --exit-with-session startxfce4
